generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[]
}


enum ArticleStatus {
  brouillon
  publie
  planifie
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String    @default("#2563EB")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
}

model Article {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String?       @db.Text
  status          ArticleStatus @default(brouillon)
  author          String
  authorAvatar    String?
  date            DateTime      @default(now())
  readTime        Int           @default(1)
  image           String?
  content         Json
  metaTitle       String?
  metaDescription String?       @db.Text
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
}



enum ServiceType {
  particulier
  business
}

model Service {
  id              String      @id @default(cuid())
  serviceId       String      @unique
  type            ServiceType
  title           String
  icon            String
  description     String      @db.Text
  features        Json?
  ussdSteps       Json?
  appSteps        Json?
  characteristics Json?
  advantages      Json?
  useCases        Json?
  steps           Json?
  linkingMethods  Json?
  model           String?
  order           Int         @default(0)
}


model TariffMeta {
  id          String      @id @default(cuid())
  region      String      @unique
  title       String
  description String      @db.Text
  note        String?     @db.Text
  rows        TariffRow[]
}

model TariffRow {
  id                 String     @id @default(cuid())
  min                Float
  max                Float?
  fraisRetrait       Float?
  fraisEnvoi         Float?
  minEnvoi           Float?
  maxEnvoi           Float?
  frais              Float?
  fraisBmoVersAutres Float?
  fraisAutresVersBmo String?
  order              Int        @default(0)
  tariffMetaId       String
  tariffMeta         TariffMeta @relation(fields: [tariffMetaId], references: [id], onDelete: Cascade)
}

model InternationalCountry {
  id    String @id @default(cuid())
  name  String
  order Int    @default(0)
}

// ─── Network ─────────────────────────────────────────────────────────────────

model Microfinance {
  id       String  @id @default(cuid())
  name     String  @unique
  agencies Int
  logo     String?
  lat      Float?
  lng      Float?
  address  String?
  order    Int     @default(0)
}

model Marchand {
  id         String  @id @default(cuid())
  token      String  @unique @default(cuid())
  name       String
  phone      String  @default("")
  email      String  @default("")
  country    String  @default("Bénin")
  department String?
  city       String?
  quartier   String?
  lat        Float?
  lng        Float?
  address    String?
  photo      String?
  logo       String?
  active     Boolean @default(false)
  order      Int     @default(0)
}

model GabAtm {
  id       String  @id @default(cuid())
  city     String
  location String
  lat      Float?
  lng      Float?
  address  String?   // reverse geocoding auto
  logo     String?
  order    Int     @default(0)
}

model Partner {
  id          String  @id @default(cuid())
  name        String  @unique
  category    String
  description String  @db.Text
  logo        String?
  lat         Float?
  lng         Float?
  address     String?
  order       Int     @default(0)
}

model ContactForm {
  id        String   @id @default(cuid())
  firstname String
  lastname  String
  email     String
  telephone String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
}